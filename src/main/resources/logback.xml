<configuration>
    <appender name="APPENDER" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%-5level] - %msg%n - [%thread, %logger{36}]%n</pattern>
        </encoder>
    </appender>
    <root level="trace">
        <appender-ref ref="APPENDER"/>
    </root>
</configuration>